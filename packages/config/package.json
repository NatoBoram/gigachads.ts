{
	"name": "@natoboram/gigachads.ts-config",
	"version": "0.0.0",
	"description": "An example config for the most gigachad project template for TypeScript monorepos",
	"keywords": [
		"eslint",
		"gigachad",
		"markdownlint",
		"monorepo",
		"prettier",
		"project-template",
